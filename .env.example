# Buildo-bot environment variables
# Copy to .env and fill in real values. .env is gitignored.
# Never commit real .env to GitHub - use GitHub Secrets for CI/CD.

# Telegram (from BotFather)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_REAL_TOKEN
# Single admin TG ID - only this user can run /admin commands
ADMIN_TELEGRAM_ID=6318513424

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# LLM
# OpenRouter is the primary path (multi-model with fallback chain)
OPENROUTER_API_KEY=REPLACE_WITH_OR_KEY
# Direct MiniMax (Anthropic-compatible), optional fallback
LLM_API_KEY=REPLACE_WITH_LLM_KEY
LLM_BASE_URL=https://api.minimaxi.chat/v1
LLM_MODEL=MiniMax-Text-01

# Redis (FSM)
# Production: redis://default:REDACTED@host:port/0
REDIS_URL=redis://localhost:***@0

# Layero (hosting)
LAYERO_API_TOKEN=REPLACE_WITH_LAYERO_TOKEN

# reg.ru (domains)
REGRU_API_LOGIN=REPLACE_WITH_LOGIN
REGRU_API_PASSWORD=REPLACE_WITH_PASSWORD

# Beget (optional, Phase 1.5)
BEGET_API_LOGIN=
BEGET_API_PASSWORD=REPLACE_WITH_PASSWORD

# Payments
# YuKassa (fiat: SBP / cards / SberPay / T-Pay / Mir Pay)
YOOKASSA_SHOP_ID=REPLACE_WITH_SHOP_ID
YOOKASSA_SECRET_KEY=REPLACE_WITH_SECRET
# Cryptobot (crypto: BTC / USDT / ETH / TON)
CRYPTOBOT_API_TOKEN=REPLACE_WITH_CRYPTOBOT_TOKEN
# Telegram Stars - no key needed, native in bot

# Runtime
ENVIRONMENT=production
LOG_LEVEL=INFO
HEALTH_PORT=8080
WEBHOOK_URL=https://your-domain.com/webhook/telegram
