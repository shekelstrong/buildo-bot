# Buildo-bot environment variables
# Copy to .env (or to HOME/.buildo-bot.env on the server) and fill real values.
# Never commit real .env to GitHub - use GitHub Secrets for CI/CD.

# Telegram
TELEGRAM_BOT_TOKEN=PASTE_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=6318513424

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=PASTE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=PASTE_ANON_KEY

# LLM - PRIMARY is MiniMax M3 (same model Hermes Agent uses)
# User-provided key, works on api.minimaxi.chat/anthropic/v1/messages
LLM_API_KEY=PASTE_USER_PROVIDED_LLM_KEY
LLM_BASE_URL=https://api.minimaxi.chat/anthropic/v1/messages
LLM_MODEL=MiniMax-Text-01
# OpenRouter is OPTIONAL fallback (used if MiniMax fails 3x)
OPENROUTER_API_KEY=PASTE_OPENROUTER_KEY

# Redis (FSM)
REDIS_URL=redis://buildo-redis:6379/0

# Layero (hosting) - PRIMARY for simple sites
LAYERO_API_TOKEN=PASTE_LAYERO_TOKEN

# reg.ru (domains) - PRIMARY
REGRU_API_LOGIN=PASTE_LOGIN
REGRU_API_PASSWORD=PASTE_PASSWORD

# Beget (optional, Phase 1.5 - fallback domains + VPS + mail)
BEGET_API_LOGIN=
BEGET_API_PASSWORD=PASTE_BEGET_PASSWORD

# Payments
# YuKassa (fiat: SBP / cards / SberPay / T-Pay / Mir Pay)
YOOKASSA_SHOP_ID=PASTE_SHOP_ID
YOOKASSA_SECRET_KEY=PASTE_YOOKASSA_SECRET
# Cryptobot (crypto: BTC / USDT / ETH / TON)
CRYPTOBOT_API_TOKEN=PASTE_CRYPTOBOT_TOKEN
# Telegram Stars - no key needed, native in bot

# Runtime
ENVIRONMENT=production
LOG_LEVEL=INFO
HEALTH_PORT=8080
WEBHOOK_URL=https://your-domain.com/webhook/telegram
